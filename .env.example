# Gnosis Chain Deployment Configuration

# Private key for deployment account (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Gnosis Chain RPC URL
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Gnosisscan API key for contract verification
GNOSISSCAN_API_KEY=your_gnosisscan_api_key_here

# Optional: Monero RPC URL for LP operations
MONERO_RPC_URL=http://localhost:18081
